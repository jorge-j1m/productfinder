{
  "name": "@repo/database",
  "type": "module",
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "lint": "eslint",
    "check-types": "tsc --noEmit",
    "employee-auth": "npx @better-auth/cli generate --config ./src/employee-auth.ts --output ./src/employee-auth-schema.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schemas.ts",
      "default": "./src/schemas.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./db": {
      "types": "./src/db.ts",
      "default": "./src/db.ts"
    }
  },
  "dependencies": {
    "better-auth": "^1.3.26",
    "drizzle-orm": "^0.44.6",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.16.3",
    "typeid-js": "^1.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.3.26",
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "drizzle-kit": "^0.31.5",
    "eslint": "^9",
    "typescript": "latest"
  }
}
