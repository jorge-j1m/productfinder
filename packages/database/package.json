{
  "name": "@repo/database",
  "type": "module",
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "lint": "eslint",
    "check-types": "tsc --noEmit",
    "employee-auth": "npx @better-auth/cli generate --config ./src/employee-auth.ts --output ./src/employee-auth-schema.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./db": {
      "types": "./src/db.ts",
      "default": "./src/db.ts"
    },
    "./store-brands": {
      "types": "./src/entities/store-brands/index.ts",
      "default": "./src/entities/store-brands/index.ts"
    },
    "./stores": {
      "types": "./src/entities/stores/index.ts",
      "default": "./src/entities/stores/index.ts"
    },
    "./employees": {
      "types": "./src/entities/employees/index.ts",
      "default": "./src/entities/employees/index.ts"
    }
  },
  "dependencies": {
    "better-auth": "^1.4.18",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.18.0",
    "typeid-js": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.18",
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3"
  }
}
