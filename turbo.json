{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": ["ADMIN_CLIENT_URL", "BETTER_AUTH_SECRET", "BETTER_AUTH_URL", "DATABASE_URL", "LOG_LEVEL", "NEXT_PUBLIC_API_URL", "NODE_ENV", "WEB_CLIENT_URL"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["ADMIN_CLIENT_URL", "DATABASE_URL", "LOG_LEVEL", "NEXT_PUBLIC_API_URL", "NODE_ENV", "WEB_CLIENT_URL"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "test/**",
        "**/*.test.ts",
        "**/*.test.tsx"
      ],
      "env": ["LOG_LEVEL", "NODE_ENV"],
      "cache": true
    }
  }
}
