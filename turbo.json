{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": ["DATABASE_URL", "NEXT_PUBLIC_API_URL", "TEST_DATABASE_URL"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["DATABASE_URL", "NEXT_PUBLIC_API_URL", "TEST_DATABASE_URL"]
    },
    "test:setup": {
      "cache": false,
      "env": ["TEST_DATABASE_URL"]
    },
    "test": {
      "dependsOn": ["^build", "test:setup"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "test/**",
        "**/*.test.ts",
        "**/*.test.tsx",
        ".env.test",
        ".env.test.example"
      ],
      "env": ["TEST_DATABASE_URL"],
      "cache": true
    }
  }
}
